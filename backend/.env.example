# Pipeline Studio — Backend Environment Variables
# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Your project URL, e.g. https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Public anon key — safe for server-side use with RLS enabled
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — bypasses RLS, keep secret, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API → JWT Settings
# Used to verify tokens issued by Supabase Auth (HS256 projects).
# Newer Supabase projects use asymmetric JWKS signing and may not need this.
JWT_SECRET=your_jwt_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# CORS origins — JSON array; add your deployed frontend origin in production
# CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
